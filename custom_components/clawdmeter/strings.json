  "options": {
    "step": {
      "init": {
        "data": {
          "scan_interval": "Update interval (seconds)"
        },
        "data_description": {
          "scan_interval": "Seconds between updates (60-3600). The default is 300."
        },
        "description": "How often to poll the Claude usage API. The API is rate limited, so keep this reasonably high.",
        "title": "Clawdmeter options"
      }
    }
  }
}
