          "red": "Red"
        }
      },
      "plan": {
        "name": "Plan"
      },
      "runway_margin": {
        "name": "Runway margin"
      },
      "runway_pace": {
        "name": "Runway pace"
      },
      "session_peak_today": {
        "name": "Session usage peak today"
